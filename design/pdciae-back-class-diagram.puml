@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title PDCIAE Back - Diagrama de Secuencia (Flujo Principal)

actor Admin as admin
participant "LoginServlet" as login
participant "AdminRepository" as adminRepo
participant "JpaUtil" as jpa
database "PostgreSQL\n(Supabase)" as db
participant "MaterialServlet" as matServlet
participant "MaterialRepository" as matRepo
participant "MaterialDetalleServlet" as matDetalle
participant "Material" as material

== Iniciar Sesión ==

admin -> login : POST /login\n(email, password)
activate login

login -> adminRepo : findByEmail(email)
activate adminRepo

adminRepo -> jpa : createEntityManager()
activate jpa
jpa -> db : SELECT usuario WHERE email = ?
db --> jpa : Usuario
jpa --> adminRepo : EntityManager
deactivate jpa

adminRepo --> login : Optional<Usuario>
deactivate adminRepo

alt credenciales incorrectas
    login --> admin : forward /login.jsp\n(error: "Credenciales incorrectas")
else credenciales correctas
    login -> login : session.setAttribute\n("adminLogueado", usuario)
    login --> admin : redirect /dashboardAdmin
end

deactivate login

== Ver Listado de Materiales ==

admin -> matServlet : GET /materiales
activate matServlet

matServlet -> matServlet : validar sesión\n(adminLogueado)

matServlet -> matRepo : findAll()
activate matRepo

matRepo -> jpa : createEntityManager()
activate jpa
jpa -> db : SELECT * FROM materiales\nORDER BY fechaEnvio DESC
db --> jpa : List<Material>
jpa --> matRepo : EntityManager
deactivate jpa

matRepo --> matServlet : List<Material>
deactivate matRepo

matServlet -> matServlet : request.setAttribute\n("materiales", lista)
matServlet --> admin : forward /materiales.jsp
deactivate matServlet

== Ver Detalle de Material ==

admin -> matDetalle : GET /material/detalle?id=X
activate matDetalle

matDetalle -> matDetalle : validar sesión\n(adminLogueado)

matDetalle -> matRepo : findById(id)
activate matRepo

matRepo -> jpa : createEntityManager()
activate jpa
jpa -> db : SELECT * FROM materiales\nWHERE id_material = ?
db --> jpa : Material
jpa --> matRepo : EntityManager
deactivate jpa

matRepo --> matDetalle : Optional<Material>
deactivate matRepo

alt material no encontrado
    matDetalle -> matDetalle : flash(session, "flashError", mensaje)
    matDetalle --> admin : redirect /materiales
else material encontrado
    matDetalle -> matDetalle : request.setAttribute\n("material", material)
    matDetalle --> admin : forward /detalle-material.jsp
end

deactivate matDetalle

== Aprobar / Rechazar Material ==

admin -> matDetalle : POST /material/accion\n(id, accion: "ACEPTAR"|"RECHAZAR")
activate matDetalle

matDetalle -> matDetalle : validar sesión\n(adminLogueado)
matDetalle -> matDetalle : determinar EstadoMaterial\n(APROBADO | RECHAZADO)

matDetalle -> matRepo : updateEstado(id, nuevoEstado)
activate matRepo

matRepo -> jpa : createEntityManager()
activate jpa
jpa -> db : UPDATE materiales\nSET estado = ?\nWHERE id_material = ?
db --> jpa : ok
jpa --> matRepo : EntityManager
deactivate jpa

matRepo --> matDetalle : boolean (actualizado)
deactivate matRepo

alt no actualizado
    matDetalle -> matDetalle : flash(session, "flashError", mensaje)
else actualizado correctamente
    matDetalle -> matDetalle : flash(session, "flashMensaje", mensaje)
end

matDetalle --> admin : redirect /materiales
deactivate matDetalle

@enduml