@startuml
skinparam style strictuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

title PDCIAE Back - Class Diagram (actualizado)

package "Enums" {
  enum Rol {
    ADMIN
    ESTUDIANTE
    TUTOR
  }

  enum Estados {
    ACTIVO
    INACTIVO
    POR_VERIFICAR
  }

  enum EstadoMaterial {
    PENDIENTE
    APROBADO
    RECHAZADO
  }
}

package "schemas" {
  class Usuario <<entity>> {
    +id_usuario: Long
    +email: String
    +nombre: String
    +segundoNombre: String
    +apellido: String
    +segundoApellido: String
    +rol: Rol
    +password: String
    +estado: Estados
    +mustChangePassword: boolean
  }

  class Admin <<entity>> {
    +Admin(id_usuario: Long, email: String, nombre: String, apellido: String, password: String, estado: Estados)
  }

  class Material <<entity>> {
    +id: Long
    +nombreArchivo: String
    +titulo: String
    +idMateria: Long
    +nombreMateria: String
    +usuario: String
    +descripcion: String
    +tipoArchivo: String
    +fechaEnvio: LocalDateTime
    +estado: EstadoMaterial
    +costo: BigDecimal
  }
}

package "repositories" {
  class JpaUtil <<utility>> {
    +getConfigValue(key: String): String
    +getConfigValue(key: String, defaultValue: String): String
    +createEntityManager(): EntityManager
    +shutdown(): void
  }

  class UsuarioRepository <<repository>> {
    +findAll(): List<Usuario>
    +findById(id: Long): Optional<Usuario>
    +existsByEmail(email: String, excludeId: Long): boolean
    +save(usuario: Usuario): Usuario
  }

  class AdminRepository <<repository>> {
    +existsByEmail(email: String): boolean
    +findByEmail(email: String): Optional<Usuario>
    +upsertInitialAdmin(email: String, password: String, nombre: String, apellido: String): void
    +save(admin: Admin): Admin
  }

  class MaterialRepository <<repository>> {
    +findAll(): List<Material>
    +findById(id: Long): Optional<Material>
    +save(material: Material): Material
    +updateEstado(id: Long, estado: EstadoMaterial): boolean
  }
}

package "servlets" {
  class LoginServlet <<servlet>> {
    -adminRepository: AdminRepository
    +doGet(req, resp): void
    +doPost(req, resp): void
  }

  class LogoutServlet <<servlet>> {
    +doGet(req, resp): void
    +doPost(req, resp): void
  }

  class DashboardAdminServlet <<servlet>> {
    +doGet(req, resp): void
  }

  class UsuarioServlet <<servlet>> {
    -usuarioRepository: UsuarioRepository
    +doGet(req, resp): void
    +doPost(req, resp): void
  }

  class UsuarioDetalleServlet <<servlet>> {
    -usuarioRepository: UsuarioRepository
    +doGet(req, resp): void
  }

  class UsuarioCrearServlet <<servlet>> {
    -adminRepository: AdminRepository
    +doGet(req, resp): void
    +doPost(req, resp): void
  }

  class UsuarioEditarServlet <<servlet>> {
    -usuarioRepository: UsuarioRepository
    +doPost(req, resp): void
  }

  class PerfilServlet <<servlet>> {
    -adminRepository: AdminRepository
    +doGet(req, resp): void
    +doPost(req, resp): void
  }

  class MaterialServlet <<servlet>> {
    -materialRepository: MaterialRepository
    +doGet(req, resp): void
  }

  class MaterialDetalleServlet <<servlet>> {
    -materialRepository: MaterialRepository
    +doGet(req, resp): void
    +doPost(req, resp): void
  }
}

package "web" {
  class AppContextListener <<listener>> {
    +contextInitialized(sce): void
    +contextDestroyed(sce): void
  }
}

package "pdciae_back" {
  class PdciaeBackApplication {
    +main(args: String[]): void
  }
}

' JPA mapping
Usuario <|-- Admin

' Repository dependencies
UsuarioRepository --> Usuario
UsuarioRepository --> JpaUtil
AdminRepository --> Usuario
AdminRepository --> Admin
AdminRepository --> Rol
AdminRepository --> Estados
AdminRepository --> JpaUtil
MaterialRepository --> Material
MaterialRepository --> EstadoMaterial
MaterialRepository --> JpaUtil

' Servlet dependencies
LoginServlet --> AdminRepository
LoginServlet --> Usuario
LogoutServlet --> "HttpSession"
DashboardAdminServlet --> "HttpSession"
UsuarioServlet --> UsuarioRepository
UsuarioServlet --> Usuario
UsuarioServlet --> Rol
UsuarioServlet --> Estados
UsuarioDetalleServlet --> UsuarioRepository
UsuarioDetalleServlet --> Usuario
UsuarioCrearServlet --> AdminRepository
UsuarioCrearServlet --> Admin
UsuarioCrearServlet --> Estados
UsuarioEditarServlet --> UsuarioRepository
UsuarioEditarServlet --> Usuario
PerfilServlet --> AdminRepository
PerfilServlet --> Admin
PerfilServlet --> Usuario
MaterialServlet --> "HttpSession"
MaterialServlet --> MaterialRepository
MaterialServlet --> Material
MaterialDetalleServlet --> "HttpSession"
MaterialDetalleServlet --> MaterialRepository
MaterialDetalleServlet --> Material
MaterialDetalleServlet --> EstadoMaterial

' Listener dependencies
AppContextListener --> AdminRepository
AppContextListener --> JpaUtil

' Enum usage
Usuario --> Rol
Usuario --> Estados
Admin --> Rol
Admin --> Estados
Material --> EstadoMaterial

' Application-level package usage
PdciaeBackApplication ..> "servlets"
PdciaeBackApplication ..> "repositories"
PdciaeBackApplication ..> "schemas"
PdciaeBackApplication ..> "Enums"
PdciaeBackApplication ..> "web"

note right of Usuario
  @Entity
  @Table(name = "usuarios")
  @Inheritance(strategy = SINGLE_TABLE)
  @DiscriminatorColumn(name = "tipo_usuario")
end note

note right of Admin
  @DiscriminatorValue("ADMIN")
end note

note right of Material
  @Entity
  @Table(name = "materiales")
  Guarda título, nombre del archivo,
  materia, usuario, estado y costo.
end note

note right of JpaUtil
  Lee DB_URL / DATABASE_URL / JDBC_DATABASE_URL
  y permite sobrescribir driver, url, usuario,
  password y dialecto desde .env o variables de entorno.
end note

note right of AppContextListener
  Sincroniza el admin inicial usando
  ADMIN_EMAIL, ADMIN_PASSWORD,
  ADMIN_NOMBRE y ADMIN_APELLIDO.
end note

@enduml
